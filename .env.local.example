# Copiez ce fichier vers .env.local pour le développement
# Ne committez jamais ce fichier dans git

# PostgreSQL Database URL
# Format pour local: postgresql://USER:PASSWORD@localhost:5432/rouky?schema=public
# Format pour Vercel Postgres: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rouky?schema=public"

# Pour Neon (Serverless PostgreSQL)
# DATABASE_URL="postgresql://user:password@ep-cool-name-123456.us-east-2.aws.neon.tech/rouky?sslmode=require"

# Pour Supabase
# DATABASE_URL="postgresql://postgres.[YOUR-ID]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Pour development avec Vercel Postgres local
# Installez Vercel CLI: npm install -g vercel
# Puis: vercel dev
# Vercel créera automatiquement une base Postgres locale
