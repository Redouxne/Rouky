# Database Connection
# Required for Prisma to work
# Format varies by provider:

# Local PostgreSQL
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rouky?schema=public"

# Vercel Postgres (automatically created when you add PostgreSQL in Vercel)
# DATABASE_URL="postgres://default:...@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Neon (Serverless PostgreSQL)
# DATABASE_URL="postgresql://user:password@ep-cool-name-123456.us-east-2.aws.neon.tech/rouky?sslmode=require"

# Supabase
# DATABASE_URL="postgresql://postgres.[YOUR-ID]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# PostgreSQL with SSL (recommended for production)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&sslmode=require"

# Optional: NextAuth.js configuration (not used in MVP)
# NEXTAUTH_SECRET="your-secret-key-here"
# NEXTAUTH_URL="http://localhost:3000"
