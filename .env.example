# Database
# For local development with PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# For Vercel Postgres
# DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# For Neon (Serverless PostgreSQL)
# DATABASE_URL="postgresql://USER:PASSWORD@ep-cool-name-123456.us-east-2.aws.neon.tech/rouky?sslmode=require"

# For Supabase
# DATABASE_URL="postgresql://postgres.[YOUR-ID]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Optional: NextAuth.js configuration (not used in MVP)
# NEXTAUTH_SECRET="your-secret-key-here"
# NEXTAUTH_URL="http://localhost:3000"
